<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><%= @place["name"] %></h2>
  <% if current_user %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">Add Entry</a>
  <% end %>
</div>
<% if @entries.empty? %>
  <p class="text-muted">No entries yet.</p>
<% else %>
  <div class="row">
    <% @entries.each do |entry| %>
      <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title"><%= entry["title"] %></h5>
            <p class="card-text text-muted small"><%= entry["occurred_on"] %></p>
            <p class="card-text"><%= entry["description"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
<a href="/" class="btn btn-secondary mt-2">Back to Places</a>
